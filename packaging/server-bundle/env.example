# Condense server bundle — environment template. Copy this file to `.env` next to `run.sh` and
# fill in the CHANGE-ME values (or leave `.env` absent — `run.sh` falls back to this file so the
# bundle boots out of the box for a quick local try, but change INGEST_TOKEN before exposing it
# to anything other than your own machine).
#
# This is the MINIMAL viable config for the standalone server bundle (D62/D63) — the full set of
# tunables lives in the main repo's `.env.example` (Settings has ~40 fields); everything not
# listed here just uses the engine's built-in default.

# --- Store: a plain local file — no Docker, no cloud Turso account needed to try this out.
#     Relative to run.sh's own directory (run.sh cd's here first), created on first ingest.
TURSO_DATABASE_URL=file:./data/sift.db

# --- Embeddings: point at any OpenAI-compatible /v1/embeddings backend (TEI, llama-server,
#     Ollama, ...). bge-m3 => 1024 dims (EMBED_DIM defaults to 1024, matching it).
EMBED_BASE_URL=
EMBED_MODEL=bge-m3

# --- LLM: recap + the /v1/answer chat agent (OpenAI-compatible /v1/chat/completions). Any of
#     Mistral / OpenAI / a local server works — set the base URL + model + key for your provider.
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# --- Auth: the shared bearer token every /ingest and /v1/tools/* call must present.
#     CHANGE-ME: pick a real secret before this is reachable by anything but you.
INGEST_TOKEN=CHANGE-ME

# --- Bind: localhost-only by default (CLAUDE.md §3 — the upload endpoint must not face the
#     internet). 8801 keeps this bundle from colliding with a docker-compose deployment's 8000
#     on the same machine (D62).
API_BIND=127.0.0.1
API_PORT=8801
