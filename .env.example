# Condense (Sift) — environment template (README §8). Copy to .env and fill in.
# Single source of values; consumed by the typed Settings (config.py) in WP1.

# --- Store (Arthur's libSQL/Turso engine) ---
STORE_BACKEND=libsql
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Embeddings (OpenAI-shaped /v1/embeddings; bge-m3 => 1024 dims) ---
EMBED_BASE_URL=
EMBED_MODEL=bge-m3
EMBED_API_KEY=

# --- Rerank (none | llm | crossencoder) ---
RERANK_STRATEGY=llm
RERANK_BASE_URL=
RERANK_MODEL=bge-reranker-v2-m3

# --- Retrieval knobs ---
RETRIEVE_K=30
FINAL_K=1

# --- LLM (recap / llm-judge; chat.completions) ---
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# --- Chunking (Arthur's engine) ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Auth (required; no default — the /ingest bearer token) ---
INGEST_TOKEN=
