# Condense (Sift) — environment template (README §8). Copy to `.env` and fill in.
# Single source of values, consumed by the typed Settings (config.py). REQUIRED: INGEST_TOKEN.

# --- Store (Turso / libSQL; cloud or embedded-replica file, no container) ---
STORE_BACKEND=libsql
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Embeddings (host Ollama / OpenAI-compatible /v1/embeddings; bge-m3 => 1024 dims) ---
# On Linux, reach the host from a container via host.docker.internal:
#   EMBED_BASE_URL=http://host.docker.internal:11434/v1
EMBED_BASE_URL=
EMBED_MODEL=bge-m3
EMBED_DIM=1024
EMBED_API_KEY=
# Texts per embeddings HTTP call. Keep this <= a TEI deployment's --max-concurrent-requests: TEI
# consumes one concurrency permit PER INPUT STRING, so an oversized batch gets an instant 429.
EMBED_BATCH_SIZE=64
# Bounded, independent timeout phases so a dead/unreachable embed backend fails in seconds rather
# than tying up a request for a flat, undifferentiated budget (DECISIONS.md D31).
EMBED_TIMEOUT_S=60.0
EMBED_CONNECT_TIMEOUT_S=5.0
# Bounded retry (fixed 0.5s/2s/8s backoff) for HTTP 429 only — retryable per-input-count limits
# (e.g. TEI), never a real failure. Any other status still fails immediately (D34).
EMBED_RETRY_ATTEMPTS=3

# --- Rerank (none | llm | crossencoder). Default llm = zero-infra (D4); crossencoder needs the tei service. ---
RERANK_STRATEGY=llm
RERANK_BASE_URL=http://tei:80
RERANK_MODEL=bge-reranker-v2-m3
RERANK_HF_MODEL=BAAI/bge-reranker-v2-m3

# --- Retrieval (two-stage: retrieve wide -> rerank -> top-1) ---
RETRIEVE_K=30
FINAL_K=1
# Version collapse: before reranking, fold near-identical retrieved passages (typo fix, re-export,
# v1->v2 of the same doc) into one, keeping the most recently *modified* copy so a stale version
# can never out-rank its newer twin (D27/D28). Threshold is token-shingle Jaccard in [0,1].
VERSION_COLLAPSE_ENABLED=true
VERSION_SIMILARITY_THRESHOLD=0.8
# Recap: the LLM-synthesized answer over the top RECAP_CONTEXT_K reranked passages, and the
# per-source snippet length shown alongside the citation. RECAP_ENABLED=false returns the raw
# top passage with no LLM call at all (zero-infra path, D4).
RECAP_ENABLED=true
RECAP_CONTEXT_K=3
RECAP_MAX_TOKENS=512
RECAP_TEMPERATURE=0.3
SOURCE_SNIPPET_CHARS=300

# --- LLM recap + /v1/answer reference agent (OpenAI-compatible chat endpoint; optional) ---
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
# auto = try native OpenAI-style function-calling once, fall back to a prompted strict-JSON
# loop on any error and stick with it for the rest of the process (D40). native|prompted force
# one path with no fallback (debugging).
ANSWER_TOOL_MODE=auto
# Hard budgets so a runaway tool loop or a slow model can't hang a request — graceful best-effort
# answer + truncated=true instead, never a bare timeout/500 (see pipelines/answer.py).
ANSWER_MAX_TOOL_CALLS=6
ANSWER_TIMEOUT_S=120.0
ANSWER_MAX_TOKENS=1024
# Conversation state (store-level turns, D40): how many of a conversation's most recent turns
# are kept (a ring buffer) and how many days an idle conversation survives before pruning.
ANSWER_HISTORY_MAX_TURNS=20
ANSWER_HISTORY_TTL_DAYS=30
# Auto-title (D42): after the first assistant answer in a conversation, one extra small
# Completer call (budget-capped via RECAP_MAX_TOKENS/RECAP_TEMPERATURE — the same completer)
# produces a short title, stored once. Any failure falls back to the first user message
# truncated to 60 chars.
ANSWER_AUTOTITLE_ENABLED=true
# Grounding mode (D46): the trust boundary between the corpus and the model's own knowledge.
# strict = corpus-only via tools, abstains honestly when uncovered, refuses a user's request to
# bypass the documents. hybrid = may supplement with general knowledge but must label it and
# flags it in the response. open = unrestricted general assistant. Per-request
# AnswerRequest.grounding overrides this default.
ANSWER_GROUNDING_DEFAULT=strict

# --- OCR fallback (Mistral OCR; optional). When an ingested file has no extractable text
#     (a screenshot/image or a scanned/text-less doc), extract its text via the OCR API
#     instead of indexing nothing. OCR_BASE_URL=https://api.mistral.ai/v1 to enable. ---
OCR_ENABLED=false
OCR_BASE_URL=
OCR_MODEL=mistral-ocr-latest
OCR_API_KEY=
# Same bounded-timeout rationale as the embedder (see above): a short connect timeout so an
# unreachable OCR backend fails fast, a longer one for OCR itself (can be genuinely slow).
OCR_TIMEOUT_S=60.0
OCR_CONNECT_TIMEOUT_S=5.0

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
# Degenerate-chunk floor (D50): drop any token window whose decoded, whitespace-collapsed text
# is shorter than this many chars — a window landing on whitespace/template filler decodes to a
# handful of real-but-useless characters otherwise, and it still gets embedded and surfaced.
CHUNK_MIN_CHARS=24

# --- Parse guards: reject an .xlsx whose declared used-range implies an implausible cell count
#     (a stray far cell can inflate it into the millions even though real content is tiny — see
#     DECISIONS.md D34) before ever attempting the real conversion; a generic post-parse text
#     ceiling and per-file wall-clock timeout apply to every format (D39). ---
PARSE_MAX_XLSX_CELLS=2000000
PARSE_MAX_CHARS=2000000
PARSE_TIMEOUT_S=60.0

# --- Toolbox `/v1/tools/*` surface (D38): default/cap on how many hits a raw-retrieval search
#     call returns (no recap, so no LLM cost bounds it — the cap must). ---
TOOLS_SEARCH_K=8
TOOLS_SEARCH_MAX_K=20

# --- Auth: shared bearer token for /search and /ingest (REQUIRED — app fails fast without it),
#     plus optional per-consumer tokens for the `/v1` toolbox/answer surface (D38), parsed as
#     "name1:token1,name2:token2" — every token resolves to tenant "default" today; the name is
#     purely for traceability in logs. ---
INGEST_TOKEN=
AUTH_TOKENS=

# --- CORS (D55): allow-list for the Tauri desktop shell's webview, which has no same-origin
#     server to talk to and so calls an absolute, user-configured base URL — the browser then
#     enforces CORS against these values. Comma-separated; empty disables CORS handling
#     entirely. The web UI is always same-origin (relative paths) so it's unaffected either way.
CORS_ORIGINS=tauri://localhost,http://tauri.localhost,https://tauri.localhost

# --- Compose: host ports & bind ---
API_BIND=0.0.0.0
API_PORT=8000
WEB_PORT=8080
# tei host port distinct from web (8080) to avoid a clash when both run.
TEI_PORT=8081
