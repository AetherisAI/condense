{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Condense",
  "version": "0.4.0",
  "identifier": "ai.aetheris.condense",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../web run dev",
    "frontendDist": "../../web/dist",
    "beforeBuildCommand": "npm --prefix ../web run build"
  },
  "app": {
    "windows": [
      {
        "title": "Condense",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^(https://.+|http://127\\.0\\.0\\.1(:\\d+)?/.*)$"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg", "nsis"],
    "externalBin": ["binaries/sift-agent-cli"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Local-first document chat & search"
  }
}
